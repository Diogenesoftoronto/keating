{
  "name": "@keating/p2p-core",
  "version": "2.0.0",
  "type": "module",
  "description": "Hypercore/Hyperbee + Hyperswarm peer-to-peer store shared by the Keating Electron main process and the cloud seeder.",
  "license": "MPL-2.0",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "keating-seeder": "./dist/seeder.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "seeder": "bun run ./src/seeder.ts",
    "test": "bun test ./test/*.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "hyperbee": "^2.20.0",
    "hypercore": "^11.0.0",
    "hyperswarm": "^4.8.0",
    "corestore": "^7.0.0",
    "b4a": "^1.6.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
