# Output docs/assets/intro.mp4
Output docs/assets/intro.mp4

Set FontSize 18
Set Width 1200
Set Height 700
Set Padding 40
Set Theme "Catppuccin Mocha"

# Boot the Keating shell — shows the refreshed ANSI Shadow logo
Type "mise run shell"
Enter
Sleep 5s

# Inspect the current teaching policy
Type "/policy"
Enter
Sleep 2s

# List available commands
Type "/help"
Enter
Sleep 3s

Ctrl+D
Sleep 1s
